{
  "manifest_version": 3,
  "name": "YouTube Auto Ad Skipper",
  "short_name": "YT Skipper",
  "description": "Automatically skips skippable YouTube ads in the background without mouse control.",
  "version": "1.3.0",
  "minimum_chrome_version": "114",
  "homepage_url": "https://github.com/EthanNguyen1412/YouTube_Auto_AD_Skipper",
  "permissions": [
    "tabs",
    "scripting",
    "debugger",
    "alarms"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "src/utils/dom.js",
        "src/content/ad-skipper.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "YouTube Auto Ad Skipper"
  }
}
